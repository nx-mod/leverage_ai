# Leverage AI - API Keys Configuration
# 
# Copy this file to ~/.leverage_ai.env and fill in your API keys
# At least ONE key is required for Leverage AI to work
#
# The tool will automatically skip providers without keys

# Groq - Fast, free tier available
GROQ_API_KEY=your_groq_key_here

# Cloudflare - Free tier with 10k requests/day
CLOUDFLARE_API_KEY=your_cloudflare_token
CF_ACCOUNT_ID=your_cloudflare_account_id

# Charm Hyper - Free hypercredits
HYPER_API_KEY=your_hyper_key_here

# OpenRouter - Aggregator with free models
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_api_key

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key_here

# Mistral
MISTRAL_API_KEY=your_mistral_key_here

# HuggingFace
HUGGINGFACE_API_KEY=your_huggingface_token

# Optional: Enable debug logging
# DEBUG=1
